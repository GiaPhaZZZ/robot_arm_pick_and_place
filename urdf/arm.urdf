<?xml version="1.0" encoding="utf-8"?>
<robot name="arm">

  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>

  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0.1 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0.01"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://arm_bringup/meshes/base_cylinder.stl"/>
      </geometry>
      <origin xyz="0 0 0.01"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://arm_bringup/meshes/base_cylinder.stl"/>
      </geometry>
      <origin xyz="0 0 0.01"/>
    </collision>
  </link>

  <link name="platform">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.005"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://arm_bringup/meshes/top_plate.stl"/>
      </geometry>
      <origin xyz="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://arm_bringup/meshes/top_plate.stl"/>
      </geometry>
      <origin xyz="0 0 0"/>
    </collision>
  </link>

  <link name="lower_arm">
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.004" ixy="0.0" ixz="0.0" iyy="0.004" iyz="0.0" izz="0.004"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://arm_bringup/meshes/lower_arm.stl"/>
      </geometry>
      <origin xyz="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://arm_bringup/meshes/lower_arm.stl"/>
      </geometry>
      <origin xyz="0 0 0"/>
    </collision>
  </link>

  <link name="top_arm">
    <inertial>
      <mass value="0.6"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.003"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://arm_bringup/meshes/top_arm.stl"/>
      </geometry>
      <origin rpy="0 1.59 0" xyz="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://arm_bringup/meshes/top_arm.stl"/>
      </geometry>
      <origin rpy="0 1.59 0" xyz="0 0 0"/>
    </collision>
  </link>

  <link name="wrist">
    <inertial>
      <mass value="0.4"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.002"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://arm_bringup/meshes/wrist.stl"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://arm_bringup/meshes/wrist.stl"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>

  <link name="clawbase">
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://arm_bringup/meshes/clawbase.stl"/>
      </geometry>
      <origin rpy="0 3.18 0" xyz="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://arm_bringup/meshes/clawbase.stl"/>
      </geometry>
      <origin rpy="0 3.18 0" xyz="0 0 0"/>
    </collision>
  </link>

  <link name="clawr">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0005"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://arm_bringup/meshes/clawr.stl"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://arm_bringup/meshes/clawr.stl"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>

  <link name="clawl">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0005"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://arm_bringup/meshes/clawl.stl"/>
      </geometry>
      <material name="black"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://arm_bringup/meshes/clawl.stl"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>

  <joint name="joint1" type="revolute">
    <axis xyz="0 0 1" />
    <limit effort="1000.0" lower="-1.56" upper="1.58" velocity="4.5" />
    <parent link="base_link"/>
    <child link="platform"/>
    <origin rpy="0 0 -1.58" xyz="0 0 0.048"/>
  </joint>

  <joint name="joint2" type="revolute">
    <axis xyz="1 0 0" />
    <limit effort="1000.0" lower="-3.12" upper="0.0" velocity="4.5" />
    <parent link="platform"/>
    <child link="lower_arm"/>
    <origin rpy="3.12 0 0" xyz="0 0.019 0.028"/>
  </joint>

  <joint name="joint3" type="revolute">
    <axis xyz="1 0 0" />
    <limit effort="1000.0" lower="0.0" upper="3.4" velocity="4.5" />
    <parent link="lower_arm"/>
    <child link="top_arm"/>
    <origin rpy="-1.70 0 0" xyz="-0.025 0.1 0"/>
  </joint>

  <joint name="joint4" type="revolute">
    <axis xyz="1 0 0" />
    <limit effort="1000.0" lower="-0.08" upper="3.32" velocity="4.5" />
    <parent link="top_arm"/>
    <child link="wrist"/>
    <origin rpy="-1.62 0 0" xyz="0.011 0.125 0"/>
  </joint>

  <joint name="joint5" type="revolute">
    <axis xyz="0 1 0" />
    <limit effort="1000.0" lower="0.0" upper="3.17" velocity="4.5" />
    <parent link="wrist"/>
    <child link="clawbase"/>
    <origin rpy="0 -3.17 0" xyz="0 0.063 0"/>
  </joint>

  <joint name="joint6" type="revolute">
    <axis xyz="0 0 1" />
    <limit effort="30.0" lower="0.0" upper="0.5" velocity="4.5" />
    <parent link="clawbase"/>
    <child link="clawr"/>
    <origin rpy="0 0 -0.81" xyz="0.011 0.034 0"/>
  </joint>

  <joint name="joint7" type="revolute">
    <axis xyz="0 0 1" />
    <limit effort="30.0" lower="-0.5" upper="0.0" velocity="4.5" />
    <parent link="clawbase"/>
    <child link="clawl"/>
    <origin rpy="0 0 0.72" xyz="-0.016 0.030 0"/>
    <mimic joint="joint6" multiplier="-1" offset="0" />
  </joint>

  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>    
    </hardware>

    <joint name="joint1">
      <command_interface name="position">
        <param name="min">-1.57</param>
        <param name="max">1.57</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint2">
      <command_interface name="position">
        <param name="min">-3.12</param> <param name="max">0.0</param>   </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint3">
      <command_interface name="position">
        <param name="min">0.0</param>   <param name="max">3.4</param>   </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint4">
      <command_interface name="position">
        <param name="min">-1.7</param>
        <param name="max">1.7</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint5">
      <command_interface name="position">
        <param name="min">0.0</param>   <param name="max">3.17</param>  </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint6">
      <command_interface name="position">
        <param name="min">0.0</param> <param name="max">0.5</param> 
      </command_interface>
      <command_interface name="effort"/> <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint7">
      <param name="mimic">joint6</param>        <!-- leader joint -->
      <param name="mimic_multiplier">-1.0</param> <!-- mirror direction -->
      <param name="mimic_offset">0.0</param>
      <state_interface name="position"/>        <!-- read-only state is fine -->
      <state_interface name="velocity"/>
    </joint>

  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>/home/phat/b_arm/install/arm_bringup/share/arm_bringup/config/ros2_controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo reference="clawr">
    <mu1>3.0</mu1>
    <mu2>3.0</mu2>
    <kp>10000000.0</kp> <kd>1.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>

  <gazebo reference="clawl">
    <mu1>3.0</mu1>
    <mu2>3.0</mu2>
    <kp>10000000.0</kp> <kd>1.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>

</robot>